{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Codex Tools",
  "version": "0.1.9",
  "identifier": "cn.sai.codex-tools",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Codex Tools",
        "width": 1180,
        "height": 780,
        "minWidth": 1060,
        "minHeight": 720,
        "visible": true,
        "skipTaskbar": false,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico",
      "icons/icon.icns",
      "icons/icon.png"
    ]
  }
}
